{
  "name": "hackerweb",
  "version": "1.0.0",
  "type": "module",
  "devDependencies": {
"prettier": "^3.8.1",
    "vite": "^8.0.8"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write 'assets/**/*.{js,css}' '*.html'",
    "format:check": "prettier --check 'assets/**/*.{js,css}' '*.html'",
    "deploy": "git checkout gh-pages && git merge master && git push origin gh-pages && git checkout master"
  }
}
